# 作为模板（不包含敏感信息）
# 环境设置
ENVIRONMENT=development

# CORS 配置
# 支持逗号分隔，也支持 JSON 数组字符串。
BACKEND_CORS_ORIGINS=http://localhost:3000,http://127.0.0.1:3000,http://localhost:5173,http://127.0.0.1:5173

# 请求日志配置
REQUEST_ID_HEADER=X-Request-ID
SLOW_REQUEST_THRESHOLD_MS=800

# 开发环境数据库
DEV_DB_DRIVER=mysql+mysqlconnector
DEV_DB_USER=your_mysql_user
DEV_DB_PASSWORD=your_mysql_password
DEV_DB_HOST=localhost
DEV_DB_PORT=3306
DEV_DB_NAME=couple_diary_dev
DEV_DB_CHARSET=utf8mb4
DEV_DB_ECHO=True
DEV_DB_POOL_SIZE=5
DEV_DB_MAX_OVERFLOW=10
DEV_DB_POOL_RECYCLE=3600
DEV_DB_POOL_TIMEOUT=30

# 生产环境数据库
PROD_DB_DRIVER=mysql+mysqlconnector
PROD_DB_USER=your_mysql_user
PROD_DB_PASSWORD=your_mysql_password
PROD_DB_HOST=localhost
PROD_DB_PORT=3306
PROD_DB_NAME=couple_diary_prod
PROD_DB_CHARSET=utf8mb4
PROD_DB_ECHO=True
PROD_DB_POOL_SIZE=5
PROD_DB_MAX_OVERFLOW=10
PROD_DB_POOL_RECYCLE=3600
PROD_DB_POOL_TIMEOUT=30

# 测试环境数据库
TEST_DB_DRIVER=mysql+mysqlconnector
TEST_DB_USER=your_mysql_user
TEST_DB_PASSWORD=your_mysql_password
TEST_DB_HOST=localhost
TEST_DB_PORT=3306
TEST_DB_NAME=couple_diary_test
TEST_DB_CHARSET=utf8mb4
TEST_DB_ECHO=True
TEST_DB_POOL_SIZE=5
TEST_DB_MAX_OVERFLOW=10
TEST_DB_POOL_RECYCLE=3600
TEST_DB_POOL_TIMEOUT=30
